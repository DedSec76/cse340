<section class="hero">
    <h1>Welcome to CSE Motors!</h1>

    <%- messages() %>

    <div class="hero_tag">
        <picture>
            <source srcset="/images/vehicles/delorean.jpg" media="(min-width: 525px)" >
            <img src="/images/vehicles/delorean-tn.jpg" alt="Delorean Car Image">
        </picture>
        <div class="hero_description">
            <span class="title">DMC Delorean</span>
            <p>3 Cup holders</p>
            <p>Superman doors</p>
            <p>Fuzzy dice!</p>
            <a href="/inv/detail/23"><img src="images/site/own_today.png" alt="own today image"></a>
        </div>
    </div>
</section>

<article class="details">

    <section class="reviews">
        <h2>DMC Delorean Reviews</h2>
        <ul>
            <li>"So fast it's almost like traveling in time." (4/5)</li>
            <li>"Coolest ride on the road." (4/5)</li>
            <li>"I'm feeling McFly!" (5/5)</li>
            <li>"The most futuristic ride of our day." (4.5/5)</li>
            <li>"80's livin and I love it!" (5/5)</li>
        </ul>
    </section>

    <section class="upgrades">
        <h2>Delorean Udgrades</h2>

        <div class="container_upgrades">
            <figure>
                <div class="background">
                    <img src="/images/upgrades/flux-cap.png" alt="flux capacitor image">
                </div>
                <figcaption><a href="#">Flux Capacitor</a></figcaption>
            </figure>
            
            <figure>
                <div class="background">
                    <img src="/images/upgrades/flame.jpg" alt="flame decals image">
                </div>
                <figcaption><a href="#">Flame Decals</a></figcaption>
            </figure>
            
            <figure>
                <div class="background">
                    <img src="/images/upgrades/bumper_sticker.jpg" alt="bumper stickers image">
                </div>
                <figcaption><a href="#">Bumper Stickers</a></figcaption>
            </figure>
            
            <figure>
                <div class="background">
                    <img src="/images/upgrades/hub-cap.jpg" alt="hub caps image">
                </div>
                <figcaption><a href="#">Hub Caps</a></figcaption>
            </figure>
        </div>
    </section>

</article>