<% if (title) { %>
    <%- messages() %>
    <h1><%= title %></h1>

    <% if (errors) { %>
        <ul class="notice">
        <% errors.array().forEach(error => { %>
                <li><%= error.msg %></li>
        <% }) %>
        </ul> 
    <% } %>
    
    <section class="updateContainer">
        <form id="updateAccount" class="account_form" action="/account/update" method="post">
            <label for="firstname">First name</label>
            <input type="text" id="firstname" name="account_firstname" autocomplete="additional-name" required value="<%= account_firstname %>">

            <label for="lastname">Last name</label>
            <input type="text" id="lastname" name="account_lastname" autocomplete="family-name" required value="<%= account_lastname %>">

            <label for="email">E-mail address</label>
            <input type="email" id="email" name="account_email" autocomplete="email" required placeholder="Enter a valid email address" value="<%= account_email %>">

            <input type="hidden" name="account_id" value="<%= account_id %>">
        
            <button class="btn_account" disabled>Update</button>
        </form>
    </section>

    <h2>Update Password</h2>

    <section class="updateContainer">
        <form id="passwordForm" class="account_form" action="/account/update-password" method="post">
            <span class="advice">Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character</span>
            
            <p>*note your original password will be changed.</p>
            
            <label for="password">Password</label>
            <input type="password" id="password" name="account_password" pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$" required>

            <input type="hidden" name="account_id" value="<%= account_id %>">

            <span id="pswdBtn">Show Password</span>
            <button class="btn_account" disabled>Change Password</button>
        </form>
    </section>

    <script src="../../js/inv-update.js"></script>
    <script src="/js/script.js"></script>
    
<% } else { 
    res.redirect('/account/')
} %>


