<% if (title) { %>
    <h1><%= title %></h1>
<% } else {
    res.redirect("/")
}%>

<%- messages() %>

<% if (errors) { %>
    <ul class="notice">
        <% errors.array().forEach(error => { %>
            <li><%= error.msg %></li>
        <% }) %>
    </ul>
<% } %>

<section class="account_container">
    <form class="account_form" action="/account/login" method="post">
        <label for="email">E-mail:</label>
        <input type="email" id="email" name="account_email" autocomplete="email" required value="<%= locals.account_email %>">

        <label for="password">Password:</label>
        <span class="advice">Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character</span>
        <input type="password" id="password" name="account_password" pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$" required>

        <button class="btn_account">Login</button>
    </form>

    <p>No account? <a href="/account/register">Sign-up</a></p>
</section>