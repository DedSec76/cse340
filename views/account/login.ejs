<h1><%= title %></h1>

<%- messages() %>

<section class="account_container">
    <form class="account_form">
        <label for="email">E-mail:</label>
        <input type="email" id="email" name="account_email" autocomplete="email">

        <label for="password">Password:</label>
        <input type="password" id="password" name="account_password">

        <button class="btn_account">Login</button>
    </form>

    <p>No account? <a href="/account/register">Sign-up</a></p>
</section>