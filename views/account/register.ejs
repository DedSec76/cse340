<% if (title) { %>
    <h1><%= title %></h1>
<% } else {
    res.redirect("/")
}%>

<%- messages() %>

<% if (errors) { %>
    <ul class="notice">
   <% errors.array().forEach(error => { %>
        <li><%= error.msg %></li>
    <% }) %>
    </ul>
<% } %>

<section class="account_container">
    <p>All fields are required.</p>
    <form class="account_form" action="/account/register" method="post">
        <label for="firstname">First name</label>
        <input type="text" id="firstname" name="account_firstname" autocomplete="additional-name" required>

        <label for="lastname">Last name</label>
        <input type="text" id="lastname" name="account_lastname" autocomplete="family-name" required>

        <label for="email">E-mail address</label>
        <input type="email" id="email" name="account_email" autocomplete="email" required placeholder="Enter a valid email address">

        <label for="password">Password</label>
        <span id="pswd_detail">Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character</span>
        <input type="password" id="password" name="account_password" pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$" required>

        <span id="pswdBtn">Show Password</span>

        <button class="btn_account">Register</button>
    </form>
</section>

<script src="/js/script.js"></script>