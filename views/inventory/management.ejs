
<% if(title) { %>
    <h1><%= title %></h1>
    <%- messages() %>

    <ul class="standard_link">
        <li><a href="/inv/new-classification">Add New Classification</a></li>
        <li><a href="/inv/new-vehicle">Add New Vehicle</a></li>
    </ul>
    
    <div class="manageInventory">
        <h2>Manage Inventory</h2>
        <p>Choose a classification to see those inventory items.</p>
        
        <%- classificationSelect %>
        
        <table id="inventoryDisplay"></table>
    </div>

    <noscript>JavaScript must be enabled to use this page.</noscript>

    <script src="../../js/inventory.js"></script>
    
<% } else {
    res.redirect('/')
} %> 

