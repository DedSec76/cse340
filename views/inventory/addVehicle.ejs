
<% if (title) { %>
    <h1><%= title %></h1>

    <% if (errors) { %>
        <ul class="notices">
            <% errors.array().forEach(error => { %>
                <li><%= error.msg %></li>
            <% }) %>
        </ul>
    <% } %>

    <section class="account_container">
        <p>Field is required.</p>

        <form class="account_form" action="/inv/new-vehicle" method="post">
            <label for="classificationSelect">Classification</label>
            <%- list_classification %>

            <label for="make">Make</label>
            <input type="text" id="make" name="inv_make" pattern="^[A-Za-zñÑ]+(\s[A-Za-zñÑ]+)*$" minlength="3" placeholder="Min of 3 characters" value="<%= locals.inv_make %>" required>

            <label for="model">Model</label>
            <input type="text" id="model" name="inv_model" pattern="^[A-Za-zñÑ]+(\s[A-Za-zñÑ]+)*$" minlength="3" placeholder="Min of 3 characters" value="<%= locals.inv_model %>" required>

            <label for="description">Description</label>
            <textarea id="description" name="inv_description" minlength="5" required><%= locals.inv_description %></textarea>

            <label for="image">Image Path</label>
            <input type="text" id="image" name="inv_image" value="/images/vehicles/no-image.png">

            <label for="thumbnail">Thumbnail Path</label>
            <input type="text" id="thumbnail" name="inv_thumbnail" value="/images/vehicles/no-image-tn.png">

            <label for="price">Price</label>
            <input type="number" step="0.01" id="price" name="inv_price" min="0" max="999999" placeholder="decimal or integer" value="<%= locals.inv_price %>" required>

            <label for="year">Year</label>
            <input type="number" step="0.01" id="year" name="inv_year" min="1800" max="2050" placeholder="4-digits year" value="<%= locals.inv_year %>" required>

            <label for="miles">Miles</label>
            <input type="number" step="0.01" id="miles" name="inv_miles" min="0" max="999999" placeholder="digits only" value="<%= locals.inv_miles %>" required>

            <label for="color">Color</label>
            <input type="text" id="color" name="inv_color" pattern="[a-zA-Z]{2,}" value="<%= locals.inv_color %>" required>

            <button class="btn_account">Add Vehicle</button>
        </form>
    </section>

<% } else {
    res.redirect('/inv')
} %>